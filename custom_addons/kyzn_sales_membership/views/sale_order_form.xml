<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_kyzn" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.kyzn</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//header/field[@name='state']" position="after">
                <field name="status_validasi" widget="statusbar"
                       statusbar_visible="to_validate,need_revision,validated"/>
            </xpath>

            <xpath expr="//header/button[@name='action_confirm']" position="before">
                <button name="action_submit_validation" string="Submit Validasi" type="object" class="btn-primary"
                        invisible="status_validasi != 'need_revision'"
                        groups="kyzn_sales_membership.group_kyzn_sales_executive"/>
                <button name="action_validate" string="Validasi" type="object" class="btn-success"
                        invisible="status_validasi != 'to_validate'"
                        groups="kyzn_sales_membership.group_kyzn_sales_admin"/>
                <button name="action_need_revision" string="Need Revision" type="object" class="btn-warning"
                        invisible="status_validasi != 'to_validate'"
                        groups="kyzn_sales_membership.group_kyzn_sales_admin"/>
            </xpath>

            <xpath expr="//group[@name='order_details']" position="after">
                <group string="Informasi Membership &amp; Transaksi">
                    <group>
                        <field name="membership_type_id" options="{'no_create': True}"/>
                        <field name="jenis_transaksi"/>
                        <field name="tanggal_mulai"/>
                        <field name="tanggal_expiry"/>
                    </group>
                    <group>
                        <field name="metode_pembayaran"/>
                        <field name="tanggal_pembayaran"/>
                        <field name="nilai_pembayaran"/>
                        <field name="status_validasi" readonly="1"/>
                        <field name="follow_up_status"/> </group>
                </group>
            </xpath>

            <xpath expr="//page[@name='order_lines']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="Riwayat Validasi" name="page_validation">
                    <field name="validation_ids" readonly="1">
                      <tree string="Riwayat Validasi" default_order="create_date desc">
                          <field name="create_date" string="Tanggal"/>
                          <field name="sales_admin_id"/>
                          <field name="status_validasi"
                                 decoration-danger="status_validasi == 'open'"
                                 decoration-warning="status_validasi == 'resolved'"
                                 decoration-success="status_validasi == 'confirmed'"/>
                          <field name="catatan_koreksi"/>
                      </tree>
                  </field>
                </page>
            </xpath>

        </field>
    </record>

    <record id="view_wizard_need_revision_form" model="ir.ui.view">
        <field name="name">kyzn.wizard.need.revision.form</field>
        <field name="model">kyzn.wizard.need.revision</field>
        <field name="arch" type="xml">
            <form string="Need Revision">
                <sheet>
                    <group>
                        <field name="sale_order_id" readonly="1"/>
                        <field name="catatan_koreksi"
                               placeholder="Tulis catatan koreksi untuk Sales Executive..."/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm" string="Konfirmasi" type="object" class="btn-primary"/>
                    <button string="Batal" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
