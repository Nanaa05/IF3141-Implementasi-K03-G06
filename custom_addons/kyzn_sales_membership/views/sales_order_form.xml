<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_kyzn" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.kyzn</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='order_details']" position="after">
                <group string="Informasi Membership &amp; Transaksi">
                    <group>
                        <field name="membership_type_id" options="{'no_create': True}"/>
                        <field name="jenis_transaksi"/>
                        <field name="tanggal_mulai"/>
                        <field name="tanggal_expiry"/>
                    </group>
                    <group>
                        <field name="metode_pembayaran"/>
                        <field name="tanggal_pembayaran"/>
                        <field name="nilai_pembayaran"/>
                        <field name="status_validasi" readonly="1"/>
                    </group>
                </group>
            </xpath>
            <xpath expr="//page[@name='order_lines']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>
</odoo>
