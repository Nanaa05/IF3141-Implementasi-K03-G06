<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_kyzn_sales_order_main" model="ir.actions.act_window">
        <field name="name">Sales Membership</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_sale_order_kyzn_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Belum ada data penjualan membership.
            </p>
        </field>
    </record>

    <record id="action_kyzn_sales_order_main_tree" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_sale_order_kyzn_tree"/>
        <field name="act_window_id" ref="action_kyzn_sales_order_main"/>
    </record>

    <menuitem id="menu_kyzn_order_list"
              name="Sales Orders"
              parent="menu_kyzn_sales_root"
              action="action_kyzn_sales_order_main"
              sequence="10"/>
</odoo>